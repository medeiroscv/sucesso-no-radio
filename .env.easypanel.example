# === Sucesso no Rádio — variáveis EasyPanel ===

# Banco PostgreSQL (serviço separado no mesmo projeto)
DB_HOST=sucesso_postgres
DB_PORT=5432
DB_DATABASE=sucesso_radio
DB_USERNAME=sucesso
DB_PASSWORD=troque-esta-senha

# ou:
# DATABASE_URL=postgres://sucesso:troque-esta-senha@sucesso_postgres:5432/sucesso_radio

AUTO_INSTALL=true
BOOTSTRAP_ADMIN_USER=admin
BOOTSTRAP_ADMIN_PASSWORD=SenhaForte123!
BOOTSTRAP_ADMIN_NAME=Administrador

APP_TIMEZONE=America/Sao_Paulo
APP_NAME=Sucesso no Rádio
APP_URL=https://seu-dominio.com.br

# Asaas (financeiro — Pix + boleto)
# ASAAS_API_KEY=$aact_hmlg_...   # sandbox  |  $aact_prod_... em produção
# ASAAS_SANDBOX=true
# ASAAS_WEBHOOK_TOKEN=token-forte-opcional

# Atualizações (Admin → Configurações → Atualização)
# GITHUB_REPO=medeiroscv/sucesso-no-radio
# GITHUB_BRANCH=master
# GITHUB_TOKEN=                 # opcional (repo privado / rate limit)
# APP_UPDATE_ALLOW=false         # true só se o container tiver .git + git
